// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --- Enums ---

enum Role {
  customer
  admin
}

enum ProductCategory {
  MENS
  WOMANS
  GOODS
}

enum OrderStatus {
  pending
  paid
  shipped
}

// --- Models ---

model User {
  id         String   @id @default(uuid()) @db.Uuid
  email      String   @unique
  password   String   
  firstName  String   @map("first_name")
  lastName   String   @map("last_name")
  role       Role   @default(customer)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  restorePasswords RestorePassword?
  addresses  Address[]
  orders     Order[]
  wishlists  Wishlist[]
  cartItems  CartItem[]

  @@map("users")
}

model RestorePassword {
  id            String   @id @default(uuid()) @db.Uuid
  token         String   @unique
  expireAt      DateTime @map("expire_at")
  userId        String   @map("user_id")@unique @db.Uuid
  user          User     @relation(fields: [userId], references: [id])

  @@map("restore_passwords")
}

model Address {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  title         String?  @db.VarChar(100)
  isDefault     Boolean  @default(false) @map("is_default")
  country       String
  stateProvince String   @map("state_province")
  city          String
  postCode      String   @map("post_code")
  addressLine1  String   @map("address_line1")
  addressLine2  String?  @map("address_line2")
  phone         String
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user          User     @relation(fields: [userId], references: [id])

  @@map("addresses")
}

model Collection {
  id          String    @id @default(uuid()) @db.Uuid
  name        String
  description String?
  products    Product[]

  @@map("collections")
}

model Type {
  id          String    @id @default(uuid()) @db.Uuid
  name        String
  description String?
  products    Product[]

  @@map("types")
}

model Product {
  id            String          @id @default(uuid()) @db.Uuid
  name          String          @db.VarChar(255)
  description   String
  basePrice     Decimal         @map("base_price") @db.Decimal(10, 2)
  discountPrice Decimal?        @map("discount_price") @db.Decimal(10, 2)
  category      ProductCategory
  specs         String[]
  collectionId  String?         @map("collection_id") @db.Uuid
  typeId        String          @map("type_id") @db.Uuid
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")
  deletedAt     DateTime?       @map("deleted_at")

  collection    Collection?     @relation(fields: [collectionId], references: [id])
  productType   Type            @relation(fields: [typeId], references: [id])
  variants      ProductVariant[]
  images        ProductImage[]
  wishlistedBy  Wishlist[]

  @@map("products")
}

model ProductVariant {
  id            String      @id @default(uuid()) @db.Uuid
  productId     String      @map("product_id") @db.Uuid
  sku           String      @unique @db.VarChar(255)
  size          String      @db.VarChar(255)
  color         String      @db.VarChar(255)
  stockQuantity Int         @default(0) @map("stock_quantity")

  product       Product     @relation(fields: [productId], references: [id])
  orderItems    OrderItem[]
  cartItems     CartItem[]

  @@map("product_variants")
}

model ProductImage {
  id        String  @id @default(uuid()) @db.Uuid
  productId String  @map("product_id") @db.Uuid
  url       String
  color     String  @db.VarChar(255)
  isMain    Boolean @default(false) @map("is_main")
  order     Int     @default(0)

  product   Product @relation(fields: [productId], references: [id])

  @@map("product_images")
}

model Order {
  id          String      @id @default(uuid()) @db.Uuid
  userId      String      @map("user_id") @db.Uuid
  totalAmount Decimal     @map("total_amount") @db.Decimal(10, 2)
  status      OrderStatus
  createdAt   DateTime    @default(now()) @map("created_at")

  user        User        @relation(fields: [userId], references: [id])
  items       OrderItem[]

  @@map("orders")
}

model OrderItem {
  id              String         @id @default(uuid()) @db.Uuid
  orderId         String         @map("order_id") @db.Uuid
  variantId       String         @map("variant_id") @db.Uuid
  quantity        Int
  priceAtPurchase Decimal        @map("price_at_purchase") @db.Decimal(10, 2)

  order           Order          @relation(fields: [orderId], references: [id])
  variant         ProductVariant @relation(fields: [variantId], references: [id])

  @@map("order_items")
}

model Wishlist {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  productId String   @map("product_id") @db.Uuid
  addedAt   DateTime @default(now()) @map("added_at")

  user      User     @relation(fields: [userId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])

  @@unique([userId, productId])
  @@map("wishlists")
}

model CartItem {
  id        String         @id @default(uuid()) @db.Uuid
  userId    String         @map("user_id") @db.Uuid
  variantId String         @map("variant_id") @db.Uuid
  quantity  Int

  user      User           @relation(fields: [userId], references: [id])
  variant   ProductVariant @relation(fields: [variantId], references: [id])

  @@unique([userId, variantId])
  @@map("cart_items")
}